#!/bin/bash
# NEXUS SketchyBar config — auto-runs on SketchyBar startup

# ── Bar ───────────────────────────────────────────────────────────────────────
sketchybar --bar \
  height=32 \
  blur_radius=20 \
  position=top \
  sticky=on \
  padding_left=12 \
  padding_right=12 \
  color=0xBB0E1420 \
  border_width=1 \
  border_color=0x22FFFFFF

sketchybar --default \
  icon.font="SF Pro:Semibold:13.0" \
  label.font="SF Pro:Semibold:12.0" \
  icon.color=0xFFF1F5F9 \
  label.color=0xFFF1F5F9 \
  icon.padding_left=6 \
  icon.padding_right=4 \
  label.padding_left=0 \
  label.padding_right=6 \
  background.corner_radius=6 \
  background.height=24 \
  background.padding_left=4 \
  background.padding_right=4

# ── Clock (center) ────────────────────────────────────────────────────────────
sketchybar --add item clock center \
  --set clock \
    update_freq=10 \
    icon.drawing=off \
    background.drawing=off \
    label.font="SF Pro:Semibold:13.0" \
    script='sketchybar --set clock label="$(date "+%a %-d %b  %-I:%M %p")"'

# ── NEXUS (right) ─────────────────────────────────────────────────────────────
PLUGIN_DIR="$HOME/.config/sketchybar/plugins"

sketchybar --add event nexus_update

sketchybar --add item nexus right \
  --set nexus \
    update_freq=60 \
    script="$PLUGIN_DIR/nexus.sh" \
    click_script="open https://nexus-sigma-livid.vercel.app" \
    background.drawing=on \
    background.color=0x115C6B79 \
    label.padding_right=8 \
  --subscribe nexus nexus_update

sketchybar --update
