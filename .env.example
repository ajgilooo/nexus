# NEXUS — Environment Variables
# Copy this to .env.local for local dev, then add the same vars in Vercel Dashboard → Settings → Environment Variables

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Single shared token — gates all /api/state reads and writes.
# Generated token (use this or replace with your own secret):
APP_TOKEN=nexus_joseph_k9mX2pL8vQnR4tYw

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ─── Notes ────────────────────────────────────────────────────────────────────
# SUPABASE_SERVICE_KEY is the "service_role" key (not the anon key).
# It bypasses RLS — safe here because auth is handled at the API function level.
# Never expose SUPABASE_SERVICE_KEY or APP_TOKEN in client-side code.
# The frontend stores APP_TOKEN in localStorage (single-user personal app).
