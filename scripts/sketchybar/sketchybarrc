#!/bin/bash
# NEXUS SketchyBar — digital command bar
# Icons: JetBrainsMono Nerd Font Mono (brew install --cask font-jetbrains-mono-nerd-font)

PLUGIN_DIR="$HOME/.config/sketchybar/plugins"
ICON_FONT="JetBrainsMono Nerd Font Mono:Regular:14.0"
MONO_FONT="JetBrainsMono Nerd Font Mono:Regular:12.0"

# ── Bar ───────────────────────────────────────────────────────────────────────
sketchybar --bar \
  height=34 \
  position=top \
  sticky=on \
  padding_left=10 \
  padding_right=10 \
  color=0xD40A0E14 \
  border_width=0 \
  shadow=off

# ── Defaults ──────────────────────────────────────────────────────────────────
sketchybar --default \
  updates=when_shown \
  icon.font="$ICON_FONT" \
  label.font="$MONO_FONT" \
  icon.color=0xFFCBD5E1 \
  label.color=0xFFCBD5E1 \
  icon.padding_left=8 \
  icon.padding_right=5 \
  label.padding_left=0 \
  label.padding_right=9 \
  background.height=26 \
  background.corner_radius=7 \
  background.drawing=on \
  background.color=0x10FFFFFF

# ── LEFT — system context ──────────────────────────────────────────────────────

# Internship / PLE countdown
sketchybar --add item nexus_countdown left \
  --set nexus_countdown \
    update_freq=3600 \
    script="$PLUGIN_DIR/nexus_countdown.sh" \
    icon.font="$ICON_FONT" \
    label.font="$MONO_FONT"

# Tiny gap
sketchybar --add item spacer_left left \
  --set spacer_left \
    icon.drawing=off label.drawing=off background.drawing=off width=4

# WiFi signal icon
sketchybar --add item nexus_wifi left \
  --set nexus_wifi \
    update_freq=30 \
    script="$PLUGIN_DIR/nexus_wifi.sh" \
    icon.font="$ICON_FONT" \
    label.font="$MONO_FONT"

# Battery
sketchybar --add item nexus_battery left \
  --set nexus_battery \
    update_freq=60 \
    script="$PLUGIN_DIR/nexus_battery.sh" \
    icon.font="$ICON_FONT" \
    label.font="$MONO_FONT"

# ── CENTER — clock ────────────────────────────────────────────────────────────
sketchybar --add item clock center \
  --set clock \
    update_freq=10 \
    icon.drawing=off \
    background.drawing=off \
    label.font="SF Pro:Semibold:13.0" \
    label.color=0xFF94A3B8 \
    script='sketchybar --set clock label="$(date "+%a %-d %b  %-I:%M %p")"'

# ── RIGHT — NEXUS pills ───────────────────────────────────────────────────────
sketchybar --add event nexus_update

# Study — QBank daily progress
sketchybar --add item nexus_study right \
  --set nexus_study \
    update_freq=60 \
    script="$PLUGIN_DIR/nexus_study.sh" \
    click_script="open 'https://nexus-sigma-livid.vercel.app'" \
    icon.font="$ICON_FONT" \
    label.font="$MONO_FONT" \
  --subscribe nexus_study nexus_update

# Training — current week + phase
sketchybar --add item nexus_train right \
  --set nexus_train \
    update_freq=3600 \
    script="$PLUGIN_DIR/nexus_train.sh" \
    click_script="open 'https://nexus-sigma-livid.vercel.app'" \
    icon.font="$ICON_FONT" \
    label.font="$MONO_FONT" \
  --subscribe nexus_train nexus_update

# XP — level + progress + coins
sketchybar --add item nexus_xp right \
  --set nexus_xp \
    update_freq=300 \
    script="$PLUGIN_DIR/nexus_xp.sh" \
    click_script="open 'https://nexus-sigma-livid.vercel.app'" \
    icon.font="$ICON_FONT" \
    label.font="$MONO_FONT" \
  --subscribe nexus_xp nexus_update

# Duty — mode indicator + high-pri todo alert
sketchybar --add item nexus right \
  --set nexus \
    update_freq=60 \
    script="$PLUGIN_DIR/nexus.sh" \
    click_script="open 'https://nexus-sigma-livid.vercel.app'" \
    icon.font="$ICON_FONT" \
    label.font="$MONO_FONT" \
  --subscribe nexus nexus_update

sketchybar --update
